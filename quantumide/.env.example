# Copy this file to .env for local development.
# .env is ignored by git. Do not commit real API keys.

# Required for the QuantumIDE OpenAI/ChatGPT agent provider.
QUANTUMIDE_OPENAI_API_KEY=

# Optional OpenAI-compatible overrides.
QUANTUMIDE_OPENAI_BASE_URL=https://api.openai.com/v1
QUANTUMIDE_OPENAI_MODEL=gpt-4.1
